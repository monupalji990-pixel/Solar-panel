{
  "apps": [
    {
      "name": "autoquote",
      "script": "./index.js",
      "node_args": "--max_old_space_size=8192",
      "max_memory_restart": "12G",
      "instances":"3",
      "exec_mode" : "cluster",
      "env": {
        "COMMON_VARIABLE": "true",
        "NODE_ENV": "staging"
      }
    },
    {
      "name": "scheduler",
      "script": "./Schedular/controller.js",
      "node_args": "--max_old_space_size=8192",
      "max_memory_restart": "5G",
      "instances":"1",
      "env": {
        "COMMON_VARIABLE": "true",
        "NODE_ENV": "staging"
      }
    }
  ]
}
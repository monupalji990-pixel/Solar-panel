{
    "apps": [
        {
            "name": "edan-power-prod",
            "script": "dist/bin/app.js",
            "node_args": "--max_old_space_size=8192",
            "max_memory_restart": "1G",
            "instances" : "8",
            "exec_mode" : "cluster",
            "env": {
                "COMMON_VARIABLE": "true",
                "NODE_ENV": "production",
                "SERVER": "online"

            },
            "env_production": {
                "NODE_ENV": "production",
                "SERVER": "online"
            }
        }
    ],
    "deploy": {
        "production": {
            "user": "gitlab-runner",
            "host": ["127.0.0.1"],
            "ref": "origin/master",
            "repo": "backend",
            "ssh_options": "StrictHostKeyChecking=no",
            "pre-setup": "npm install",
            "post-setup": "ls -la",
            "pre-deploy-local": "echo 'This is a local executed command'",
            "env": {
                "NODE_ENV": "production",
                "SERVER": "online"
            }
        }
    }
}